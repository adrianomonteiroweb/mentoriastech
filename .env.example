# Neon Postgres
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth (gere com: openssl rand -base64 32)
AUTH_SECRET=your-auth-secret-here

# Vercel Blob
BLOB_READ_WRITE_TOKEN=your-blob-token

# SMTP (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-password

# Google Calendar (OAuth2)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALENDAR_ID=your-calendar-email@gmail.com

# Google Gemini (melhoria de currículo com IA)
GEMINI_API_KEY=your-gemini-api-key
# Opcional — modelo usado na geração (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Pagar.me (PIX)
# SECRET key (sk_test_ = sandbox, sk_live_ = producao). NAO use a chave publica (pk_...).
PAGARME_SECRET_KEY=sk_test_your-secret-key
# Host unico v5; o ambiente e definido pela chave, nao pela URL. Opcional (a lib usa este default).
PAGARME_BASE_URL=https://api.pagar.me/core/v5
# Credenciais Basic Auth configuradas no endpoint de webhook do dashboard Pagar.me
PAGARME_WEBHOOK_USER=your-webhook-basic-user
PAGARME_WEBHOOK_PASSWORD=your-webhook-basic-password
