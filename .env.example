# Neon Postgres
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# URL pública canônica do site (SEO: metadata, sitemap, robots). Sem barra final.
NEXT_PUBLIC_SITE_URL=https://mentoriastech.com.br

# Auth (gere com: openssl rand -base64 32)
AUTH_SECRET=your-auth-secret-here

# Vercel Blob
BLOB_READ_WRITE_TOKEN=your-blob-token

# SMTP (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-password

# Bot de confirmação de mentoria (repo bots / send-mentorship-confirmation).
# Bearer token do endpoint GET /api/bots/scheduled-bookings. Gere com:
# openssl rand -base64 32. O mesmo valor vai no .env do bot (BOOKINGS_BOT_TOKEN).
BOOKINGS_BOT_TOKEN=your-bookings-bot-token

# Google Calendar (OAuth2)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALENDAR_ID=your-calendar-email@gmail.com

# Google Gemini (melhoria de currículo com IA + transcrição de mentorias)
GEMINI_API_KEY=your-gemini-api-key
# Opcional — modelo usado na geração (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Cron de transcrição de mentorias (GET /api/cron/transcribe-sessions).
# A Vercel injeta automaticamente Authorization: Bearer ${CRON_SECRET} nas
# chamadas agendadas em vercel.json. Gere com: openssl rand -base64 32.
CRON_SECRET=your-cron-secret

# Órbita — Formação em Squad (em desenvolvimento)
# Quando "true", exibe o link do curso na tela pública e habilita as rotas
# /formacao/*. Sem esta variável, as rotas retornam 404 (acesso só em dev).
NEXT_PUBLIC_FORMACAO_PREVIEW=true

# Pagar.me (PIX)
PAGARME_SECRET_KEY=sk_test_your-secret-key
# URL da API — teste (sandbox) ou producao
PAGARME_BASE_URL=https://sdx-api.pagar.me/core/v5   # prod: https://api.pagar.me/core/v5
# Credenciais Basic Auth configuradas no endpoint de webhook do dashboard Pagar.me
PAGARME_WEBHOOK_USER=your-webhook-basic-user
PAGARME_WEBHOOK_PASSWORD=your-webhook-basic-password
